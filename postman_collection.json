              "response": [
                {
                  "name": "200 OK",
                  "status": "OK",
                  "code": 200,
                  "header": [{ "key": "Content-Type", "value": "application/json" }],
                  "body": "{\n  \"success\": true,\n  \"message\": \"\",\n  \"data\": {\n    \"access_token\": \"<jwt>\"\n  }\n}"
