            {
              "name": "Upload File",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const res = pm.response.json();",
                      "const upload = res.data && res.data.uploadFile;",
                      "if (upload && upload.success && upload.data) {",
                      "  pm.collectionVariables.set('media_id', upload.data.mediaId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
