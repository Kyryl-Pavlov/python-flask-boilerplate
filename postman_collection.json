        {
          "name": "Media",
          "item": [
            {
              "name": "Upload File",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res.success && res.data) {",
                      "  pm.collectionVariables.set('media_id', res.data.media_id);",
